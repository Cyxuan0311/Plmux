{
  "shell": null,
  "env": {},
  "ui": {
    "refresh_hz": 60,
    "use_alternate_screen": true,
    "status_position": "bottom",
    "command_line_height": 1,
    "min_pane_rows": 3,
    "min_pane_cols": 10,
    "status_bar_style": {
      "separator": "powerline",
      "show_command": true,
      "show_session": true,
      "right_sections": "clock_host",
      "spacing": "compact",
      "mode_indicator": "full",
      "show_window_index": true,
      "show_pane_index": true,
      "gradient": false
    },
    "pane_border_style": {
      "box_style": "square",
      "show_title": true,
      "title_position": "left",
      "active_indicator": "color"
    }
  },
  "keys": {
    "prefix": "ctrl+b",
    "command_line": ":",
    "bindings": {
      "split-vertical": ["%", "v"],
      "split-horizontal": ["\"", "s"],
      "only-pane": ["o"],
      "next-window": ["n"],
      "prev-window": ["p"],
      "new-window": ["c"],
      "close-window": ["&"],
      "copy-mode": ["["],
      "cycle-layout": [" "],
      "help": ["?"],
      "detach": ["d"],
      "focus-left": ["h"],
      "focus-right": ["l"],
      "focus-up": ["k"],
      "focus-down": ["j"],
      "resize-left": ["H"],
      "resize-right": ["L"],
      "resize-up": ["K"],
      "resize-down": ["J"],
      "zoom": ["z"]
    }
  },
  "session": {
    "auto_save": true,
    "state_path": null
  },
  "theme": "default",
  "extensions": {
    "enabled": [],
    "search_paths": ["~/.config/plmux/extensions"]
  },
  "web": {
    "host": "0.0.0.0",
    "port": 9888,
    "tls_cert": null,
    "tls_key": null,
    "auth_enabled": false,
    "tokens": [],
    "readonly_tokens": []
  },
  "custom_layouts": []
}
